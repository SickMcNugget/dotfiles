{
    "current script directory": {
        "prefix": "here",
        "body": "SCRIPT_DIR=$( cd -- \"$( dirname -- \"${BASH_SOURCE[0]}\" )\" &> /dev/null && pwd )",
        "description": "Snippet for getting the current directory of a bash script"
    },
    "rust boilerplate": {
        "prefix": "boiler",
        "body": [
            "// Written by Joren (SickMcNugget)",
            "// Date: ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
            "// ",
            "// $1",
            "\n"
        ]
    }
}
