#!/bin/bash

function usage() {
    echo "Usage: $0"
    echo "Create a tmux session with specific windows from a .tmuxw template file"
    printf "\n\n"
    echo "The .tmuxw file is comma-separated, with a separate window on each line of the file."
    printf "\nFields"
    printf "  %-26s %s\n" "1" "The name of the window"
    printf "  %-26s %s\n" "2" "An optional directory to start the window in"
    printf "  %-26s %s\n" "3" "An optional command to run in the window"
    printf "\nExamples\n"
    printf "\nA .tmuxw file that creates an editor window in the current directory and runs the 'foo' program in the 'bin' directory\n"
    printf "editor,.,vim .\n"
    printf "[none],bin,./foo\n"
    exit 1
}

function ensure_dir_exists {
    if ! [[ -d "$1" ]]; then
        echo "Directory $1 does not exist for window $2"
        tmux kill-session -t "$3"
        exit 1
    fi
}

function ensure_cmd_exists {
    cmdarray=($1)
    if ! command -v "${cmdarray[0]}" >/dev/null 2>&1 && [[ ! -f "$2/${cmdarray[0]}" ]]; then
        echo "Command ${cmdarray[0]} does not exist for window $3"
        tmux kill-session -t "$4"
        exit 1
    fi
}

if [ ! -f ".tmuxw" ]; then
    usage
fi

session=$(tmux display-message -p "#S" 2>/dev/null)

if [[ -z $TMUX ]] && [[ -z $session ]]; then
    tmux new-session -c . -d
    session=$(tmux display-message -p "#S" 2>/dev/null)
fi

while IFS=, read -r winname winfolder winexec; do
    cmd=""
    if [[ "$winname" == "[none]" ]]; then
        cmd="tmux neww"
    else
        cmd="tmux neww -n ${winname}"
    fi

    if [[ ! -z "$winfolder" ]]; then
        ensure_dir_exists "$winfolder" "$winname" "$session"

        if [[ "$winfolder" != "." ]]; then
            cmd="${cmd} -c ${winfolder}"
        fi
    fi

    eval "$cmd"

    if [[ ! -z "$winexec" ]]; then
        ensure_cmd_exists "$winexec" "$winfolder" "$winname" "$session"
        tmux send-keys "$winexec" C-m
    fi
    echo "$winname $winfolder $winexec"

done < .tmuxw

# tmux creates a default window at index 1
tmux kill-window -t 0
tmux select-window -t 0
tmux a
