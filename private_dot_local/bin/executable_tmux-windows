#!/bin/bash

function ensure_dir_exists {
    if ! [[ -d "$1" ]]; then
        echo "Directory $1 does not exist for window $2"
        tmux kill-session -t "$3"
        exit 1
    fi
}

function ensure_cmd_exists {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "Command $1 does not exist for window $2"
        tmux kill-session -t "$3"
        exit 1
    fi
}


if ! [[ -f .tmuxw ]]; then
    echo "Please create a .tmuxw file"
    exit 1
fi

session=$(tmux display-message -p "#S" 2>/dev/null)

if [[ -z $TMUX ]] && [[ -z $session ]]; then
    tmux new-session -c . -d
    session=$(tmux display-message -p "#S" 2>/dev/null)
fi

windows=($(cat .tmuxw))

for window in "${windows[@]}"; do
    winname=$(echo ${window} | cut -d "," -f 1)
    winfolder=$(echo ${window} | cut -d "," -f 2)
    winexec=$(echo ${window} | cut -d "," -f 3)
    echo "$winname $winfolder $winexec"

    # layouts:
    # [none]
    # <name>
    # <name>,<directory>
    # <name>,<directory>,<command>
    # <name>,.,<command>
    # Create a standard window if the name is [none]
    # Create a named window if the 
    #
    if [[ "$winname" == "[none]" ]]; then
        tmux neww
    elif [[ "$winname" == "$winfolder" && "$winname" == "$winexec" ]]; then
        tmux neww -n "$winname"
    elif [[ "$winname" != "$winfolder" && -z "$winexec" ]]; then
        ensure_dir_exists "$winfolder" "$winname" "$session"
        tmux neww  -c "$winfolder" -n "$winname"
    elif [[ "$winname" != "$winfolder" && ! -z "$winexec" ]]; then
        ensure_dir_exists "$winfolder" "$winname" "$session"
        ensure_cmd_exists "$winexec" "$winname" "$session"

        if [[ "$winfolder" == "." ]]; then
            tmux neww -n "$winname"
        else
            tmux neww -c "$winfolder" -n "$winname"
        fi

        tmux send-keys "$winexec" C-m
    fi
done

# tmux creates a default window at index 1
tmux kill-window -t 1
tmux select-window -t 1
tmux a
