[user]
	name = {{ .name }}
	email = {{ .email }}
[credential]
	helper = store --file ~/.my-credentials
[init]
	defaultBranch = main
[pull]
	rebase = false
[merge]
	tool = nvimdiff
{{- if .work }}
[url "git@gitlab.base"]
	insteadOf = https://gitlab.base
[url "git@gitlab.base:"]
	insteadOf = https://gitlab.base/
{{- end }}
