# ~/.profile: executed by the command interpreter for login shells.
# This file is not read by bash(1), if ~/.bash_profile or ~/.bash_login
# exists.
# see /usr/share/doc/bash/examples/startup-files for examples.
# the files are located in the bash-doc package.

# the default umask is set in /etc/profile; for setting the umask
# for ssh logins, install and configure the libpam-umask package.
#umask 022

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
	. "$HOME/.bashrc"
    fi
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi

TEXLIVE_YEAR=2024
if [ -d "/usr/local/texlive" ]; then
    export MANPATH="/usr/local/texlive/${TEXLIVE_YEAR}/texmf-dist/doc/man${MANPATH:+:${MANPATH}}"
    export INFOPATH="/usr/local/texlive/${TEXLIVE_YEAR}/texmf-dist/doc/info${INFOPATH:+:${INFOPATH}}"
    export PATH="/usr/local/texlive/${TEXLIVE_YEAR}/bin/x86_64-linux${PATH:+:${PATH}}"
fi

# Ruby: rbenv
if [ -d "$HOME/.rbenv" ]; then
    eval "$(~/.rbenv/bin/rbenv init - bash)"
fi

# Python: pyenv
export PYENV_ROOT="$HOME/.pyenv"
if [ -d "$PYENV_ROOT/bin" ]; then
    export PATH="$PYENV_ROOT/bin:$PATH"
fi
eval "$(pyenv init -)"

# Rust: Cargo
[ -d "$HOME/.cargo" ] && . "$HOME/.cargo/env"

# Golang: local modules
if [ -d "/usr/local/go/bin" ]; then
    export PATH="$PATH:/usr/local/go/bin:${HOME}/go/bin"
fi

# rke2
if [ -d "/var/lib/rancher/rke2/bin" ]; then
    export PATH="$PATH:/var/lib/rancher/rke2/bin"
fi

# Javascript: nvm
export NVM_DIR="$HOME/.config/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
